{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A master list of grocery products available in the shop.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the product" },
        "rate": { "type": "number", "description": "Price per unit" },
        "unit": { "type": "string", "description": "Unit of measurement (kg, pkt, etc.)" },
        "category": { "type": "string", "description": "Category of the grocery" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "rate", "unit"]
    },
    "StockEntry": {
      "title": "Stock Entry",
      "description": "Records of goods entering the shop.",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "Reference to the product" },
        "quantity": { "type": "number", "description": "Quantity added" },
        "entryDate": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string", "description": "UID of the owner who added it" }
      },
      "required": ["productId", "quantity", "entryDate", "ownerId"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Records of goods sold.",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "Reference to the product" },
        "quantity": { "type": "number", "description": "Quantity sold" },
        "totalAmount": { "type": "number", "description": "Total price for this sale" },
        "saleDate": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "quantity", "totalAmount", "saleDate"]
    }
  },
  "firestore": {
    "/products": { "schema": "Product", "description": "Master list of products" },
    "/stockEntries": { "schema": "StockEntry", "description": "History of stock arrivals" },
    "/sales": { "schema": "Sale", "description": "History of sales" }
  }
}
