rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic setup: Allowing public access as requested by the user
    // In a production app, you should use Firebase Auth for security.
    
    match /products/{productId} {
      allow read, write: if true;
    }

    match /stockEntries/{entryId} {
      allow read, write: if true;
    }

    match /sales/{saleId} {
      allow read, write: if true;
    }
  }
}
